# OpenAI-compatible OCR vision model server (Ollama by default)
OCR_BASE_URL=http://localhost:11434/v1
OCR_MODEL_NAME=qwen2.5vl:7b
# Ollama ignores the key's value, but the OpenAI SDK requires one to be set
OCR_API_KEY=ollama

# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Upload limits
MAX_UPLOAD_MB=20
MAX_PDF_PAGES=8

# Seconds to wait for the OCR model server to respond
OCR_REQUEST_TIMEOUT=120
